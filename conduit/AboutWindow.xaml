<Window x:Class="Conduit.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Conduit"
        mc:Ignorable="d"
        Title="Destiny Conduit Local" Height="700" Width="500" ResizeMode="NoResize" Closing="Window_Closing">
    <Grid>
        <Image x:Name="Logo" HorizontalAlignment="Left" Height="80" Margin="15,227,0,0" VerticalAlignment="Top" Width="80" />
        <Label x:Name="AboutTitle" Content="Destiny Conduit v2.0.0" HorizontalAlignment="Left" Margin="100,227,0,0" VerticalAlignment="Top" FontSize="24" FontWeight="Bold" FontFamily="Arial"/>
        <Label Content="Local standalone edition." HorizontalAlignment="Left" Margin="100,278,0,0" VerticalAlignment="Top" FontSize="14"/>
        <Label Content="CONNECTION DETAILS" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" FontSize="16"/>
        <Label Content="ABOUT" HorizontalAlignment="Left" Margin="10,184,0,0" VerticalAlignment="Top" FontSize="16"/>
        <Button Content="Restart Server" Click="RestartRift" HorizontalAlignment="Left" Margin="15,0,0,15" VerticalAlignment="Bottom" Width="110" FontSize="14" Height="23"/>
        <Button Content="Uninstall Conduit" Click="Uninstall" Margin="0,0,15,15" FontSize="14" HorizontalAlignment="Right" Width="123" Height="23" VerticalAlignment="Bottom"/>
        <Rectangle Fill="#FFF4F4F5" HorizontalAlignment="Left" Height="1" Margin="0,184,-6,0" Stroke="Black" VerticalAlignment="Top" Width="500"/>
        <Image x:Name="ConnectionQR" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="15,46,0,0" Width="120" Height="120" Visibility="Hidden" />
        <TextBlock x:Name="ConnectionSteps" Margin="148,46,10,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="56" FontSize="13" Visibility="Hidden">
            <Run Text="To control League from your phone (same Wi-Fi network), either scan the QR code on the left or browse to"/>
            <Run x:Name="HubUrl" FontWeight="Bold" Text="http://this-pc:51001"/>
            <Run Text="on your phone and enter the following code:"/>
        </TextBlock>
        <Label x:Name="CodeLabel" Content="562414" HorizontalAlignment="Left" Margin="148,107,0,0" VerticalAlignment="Top" Width="336" FontFamily="Courier New" FontSize="50" HorizontalContentAlignment="Center" Height="64" VerticalContentAlignment="Center" Visibility="Hidden"/>
        <TextBlock x:Name="NoCodeText" Margin="15,46,15,0" TextWrapping="Wrap" VerticalAlignment="Top" RenderTransformOrigin="-0.122,0.378" FontSize="14"><Run Text="To control League from your phone, please launch League at least once while Conduit is running."/><Run Text=" After that, check back here for instructions on how to connect to "/><Run Text="League from your phone."/></TextBlock>
        <Rectangle Fill="#FFF4F4F5" HorizontalAlignment="Left" Height="1" Margin="0,320,-6,0" Stroke="Black" VerticalAlignment="Top" Width="500"/>
        <Label Content="LOCAL SERVER" HorizontalAlignment="Left" Margin="10,322,0,0" VerticalAlignment="Top" FontSize="16"/>
        <Label x:Name="RiftStatusLabel" Content="Stopped" HorizontalAlignment="Left" Margin="130,326,0,0" VerticalAlignment="Top" FontSize="13" Foreground="Gray"/>
        <TextBox x:Name="RiftLog" Margin="15,358,15,95" IsReadOnly="True" TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="11" Background="#FF1E1E1E" Foreground="#FFDDDDDD"/>
        <CheckBox x:Name="AutoAcceptCheckbox" Content="Auto-accept matches" HorizontalAlignment="Left" Margin="15,0,0,70" Height="15" VerticalAlignment="Bottom" FontSize="13" Click="HandleAutoAcceptChange" />
        <CheckBox x:Name="StartOnStartupCheckbox" Content="Launch Destiny when your computer starts" HorizontalAlignment="Left" Margin="15,0,0,45" Height="15" VerticalAlignment="Bottom" FontSize="13" Click="HandleStartupChange" />
    </Grid>
</Window>
